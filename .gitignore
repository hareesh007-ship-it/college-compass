# --- Secrets ---
.env
.env.local
*.env
# env.template is safe to commit — all values are empty placeholders

# --- Python ---
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.venv/
venv/
env/

# --- Root-level legacy paths (backward compat — real data, never commit) ---
/input/
/output/

# --- macOS ---
.DS_Store
.AppleDouble

# --- Student instances — private data (PII — never commit) ---
# Add a line here for each real student you create, e.g.:
#   students/sid/
students/sid/

# Exclude outputs and generated data for all students:
students/*/output/*.xlsx
students/*/output/*.html
students/*/output/*.json
students/*/output/*.md
students/*/output/logs/
!students/*/output/.gitkeep

# Per-student catalog is generated — do not commit.
students/*/data/colleges/catalog.json

# Exception: alex-sample ships with inputs and outputs so users can see sample results
!students/alex-sample/input/
!students/alex-sample/input/**
!students/alex-sample/output/Alex - US College Selection.xlsx
!students/alex-sample/output/Alex - College Prep Gap Analysis.html
!students/alex-sample/data/colleges/catalog.json

# --- Shared data files (reference / cache) ---
# The research cache IS committed — it's the shared school research library.
# Uncomment the line below only if you want to exclude it:
# data/college_research_cache.json
data/us_news_rankings_2026.json

# --- Tool config (machine-level — not per-student, not committed) ---
config/pro.json

# --- Logs ---
students/*/data/logs/
logs/
*.log

# --- IDE ---
.idea/
.vscode/
.cursor/

# --- Jupyter ---
.ipynb_checkpoints/
